{
  "version": 1,
  "sources": {
    "runtime_rules": "prompts/runtime-rules.md",
    "openclaw_models": "config/providers.json",
    "character_core": "examples/character/character-data.json",
    "lorebook": "examples/character/lorebook.json",
    "user": "examples/USER.md",
    "player_profile_md": "examples/player-profile.md",
    "player_profile_json": "examples/player-profile.json",
    "preset_dir": "examples/character/presets",
    "active_preset": "world-sim-balanced",
    "canon": "examples/memory/canon.md",
    "state": "examples/memory/state.md",
    "summary": "examples/memory/summary.md",
    "history": "examples/memory/history.jsonl",
    "npc_profiles_dir": "examples/memory/npcs",
    "persona_seeds_dir": "examples/runtime/persona-seeds"
  },
  "bootstrap": {
    "must_load_runtime_rules_first": true
  },
  "memory": {
    "recent_history_turns": 12,
    "recent_summary_blocks": 3,
    "consolidate_every_turns": 12,
    "auto_save_every_turns": 20
  },
  "refresh_policy": {
    "runtime_rules_every_turn": true,
    "preset_every_turn": true,
    "state_every_turn": true,
    "scene_persona_every_turn": true,
    "recent_history_turns": 12,
    "summary_refresh_every_turns": 12,
    "deep_refresh_every_turns": 20,
    "deep_refresh_on_scene_change": true,
    "deep_refresh_on_onstage_shift": true
  },
  "model_defaults": {
    "narrator": {
      "temperature": 0.9,
      "max_output_tokens": 1200,
      "stream": true
    },
    "state_keeper": {
      "temperature": 0.1,
      "max_output_tokens": 480,
      "stream": false
    }
  },
  "state_policy": {
    "max_onstage_npcs": 6,
    "max_relevant_npcs": 6,
    "max_open_questions": 6,
    "carryover_clues_max": 4
  },
  "persona_policy": {
    "seed_window_turns": 12,
    "scene_seed_limit": 6,
    "longterm_min_score": 5,
    "scene_seed_allow_low_confidence": true
  },
  "entity_recovery": {
    "use_candidate_judge": true,
    "judge_role": "state_keeper_candidate",
    "max_candidates": 12
  },
  "web": {
    "default_debug": false,
    "history_page_size": 80,
    "show_state_panel": true,
    "show_debug_panel": false
  },
  "trace": {
    "enabled": true,
    "keep_last_turns": 40
  }
}
